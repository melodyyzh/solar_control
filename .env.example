# --- Agent brain ---
# OpenAI API key used by the agent execution runtime (uses your OpenAI credits).
OPENAI_API_KEY=sk-...
# Model for the agent loop. Any chat-completions model works.
OPENAI_MODEL=gpt-5-mini
# Optional: point at any OpenAI-compatible endpoint (OpenRouter, Ollama, vLLM…)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Server ---
PORT=3000
# Root folder holding the six project directories. Defaults to ./workspace
# WORKSPACE_DIR=/home/ya/sci/dashboarda/workspace

# --- Security (recommended when exposing beyond localhost/tailnet) ---
# If set, every browser/WS connection must present this token (login page asks once).
# Leave unset for open access on localhost or a private tailnet.
# DASH_TOKEN=choose-a-long-random-string

# --- Optional: experimental Claude Code provider ---
# No key needed; uses the locally installed `claude` CLI if you select it in the UI.
